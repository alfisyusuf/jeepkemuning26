---
import { urlFor } from '../lib/sanity'

interface Props { images: any[] }
const { images = [] } = Astro.props
---

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
  {images.map((item, index) => {
    // Karena kita menggunakan skema galeriItem (Fase 2)
    const isVideo = item.tipeMedia === 'video';
    const imageSource = item.fileMedia;
    const urlGambarBesar = imageSource ? urlFor(imageSource).width(1400).url() : '';
    const urlThumbnail = imageSource ? urlFor(imageSource).width(500).height(500).url() : '';
    
    return (
      <div
        class="gallery-item aspect-square bg-gray-200 rounded-lg overflow-hidden cursor-pointer relative group"
        data-src={urlGambarBesar}
        data-index={index}
      >
        {urlThumbnail && <img src={urlThumbnail} alt={item.altText || 'Galeri'} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />}
        
        <div class="absolute inset-0 bg-brand-forest/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
          {isVideo ? (
            <a href={item.videoUrl} target="_blank" class="w-full h-full flex items-center justify-center">
               <i class="fa-solid fa-circle-play text-white text-4xl"></i>
            </a>
          ) : (
            <i class="fa-solid fa-magnifying-glass-plus text-white text-3xl"></i>
          )}
        </div>
      </div>
    )
  })}
</div>

<div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
  <button id="lightbox-close" class="absolute top-6 right-6 text-white/70 hover:text-white text-4xl focus:outline-none z-50">
    <i class="fa-solid fa-xmark"></i>
  </button>
  <button id="lightbox-prev" class="absolute left-4 md:left-10 top-1/2 -translate-y-1/2 text-white/50 hover:text-white text-5xl focus:outline-none z-50 hidden md:block">
    <i class="fa-solid fa-chevron-left"></i>
  </button>
  <button id="lightbox-next" class="absolute right-4 md:right-10 top-1/2 -translate-y-1/2 text-white/50 hover:text-white text-5xl focus:outline-none z-50 hidden md:block">
    <i class="fa-solid fa-chevron-right"></i>
  </button>
  <div class="relative w-full max-w-5xl max-h-[85vh] px-4 flex justify-center items-center">
    <img id="lightbox-img" src="" alt="Galeri Besar" class="max-w-full max-h-[85vh] object-contain shadow-2xl rounded-sm transform scale-95 transition-transform duration-300" />
  </div>
</div>

<script>
  // Logika lightbox tetap sama seperti buatan Claude/Anda sebelumnya
  const galleryItems = document.querySelectorAll('.gallery-item')
  const lightbox = document.getElementById('lightbox')
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement
  const lightboxClose = document.getElementById('lightbox-close')
  const lightboxPrev = document.getElementById('lightbox-prev')
  const lightboxNext = document.getElementById('lightbox-next')
  let currentIndex = 0

  function openLightbox(index: number) {
    // Jika item tersebut mengarah ke target blank (video), jangan buka lightbox
    const hasLink = galleryItems[index].querySelector('a');
    if(hasLink) return;

    currentIndex = index
    lightboxImg.src = galleryItems[index].getAttribute('data-src') || ''
    lightbox?.classList.remove('opacity-0', 'pointer-events-none')
    setTimeout(() => lightboxImg.classList.replace('scale-95', 'scale-100'), 50)
    document.body.classList.add('lightbox-open')
  }

  function closeLightbox() {
    lightbox?.classList.add('opacity-0', 'pointer-events-none')
    lightboxImg.classList.replace('scale-100', 'scale-95')
    document.body.classList.remove('lightbox-open')
  }

  function showNext() {
    let nextIndex = (currentIndex + 1) % galleryItems.length;
    while(galleryItems[nextIndex].querySelector('a')) { // Skip jika video
       nextIndex = (nextIndex + 1) % galleryItems.length;
    }
    currentIndex = nextIndex;
    lightboxImg.src = galleryItems[currentIndex].getAttribute('data-src') || ''
  }

  function showPrev() {
    let prevIndex = (currentIndex - 1 + galleryItems.length) % galleryItems.length;
    while(galleryItems[prevIndex].querySelector('a')) { // Skip jika video
       prevIndex = (prevIndex - 1 + galleryItems.length) % galleryItems.length;
    }
    currentIndex = prevIndex;
    lightboxImg.src = galleryItems[currentIndex].getAttribute('data-src') || ''
  }

  galleryItems.forEach((item, index) => item.addEventListener('click', () => openLightbox(index)))
  lightboxClose?.addEventListener('click', closeLightbox)
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox() })
  lightboxNext?.addEventListener('click', showNext)
  lightboxPrev?.addEventListener('click', showPrev)
  
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('opacity-0')) {
      if (e.key === 'Escape') closeLightbox()
      if (e.key === 'ArrowRight') showNext()
      if (e.key === 'ArrowLeft') showPrev()
    }
  })
</script>