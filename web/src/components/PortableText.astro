---
// Renderer Portable Text ringan tanpa dependency tambahan.
// Mendukung: paragraf, h2, h3, blockquote, bold/italic, list, dan gambar.
import { urlFor } from '../lib/sanity'

interface Props { value: any[] }
const { value = [] } = Astro.props

function renderMarks(text: string, marks: string[] = []) {
  let html = text
  if (marks.includes('strong')) html = `<strong>${html}</strong>`
  if (marks.includes('em')) html = `<em>${html}</em>`
  return html
}

function blockToHtml(block: any): string {
  if (block._type === 'image') {
    return `<img src="${urlFor(block).width(1000).url()}" alt="" />`
  }
  if (block._type !== 'block') return ''

  const children = (block.children || [])
    .map((child: any) => renderMarks(child.text, child.marks))
    .join('')

  switch (block.style) {
    case 'h2': return `<h2>${children}</h2>`
    case 'h3': return `<h3>${children}</h3>`
    case 'blockquote': return `<blockquote>${children}</blockquote>`
    default: return `<p>${children}</p>`
  }
}

// Gabungkan list item (bullet) berurutan menjadi satu <ul>
const htmlParts: string[] = []
let currentList: string[] | null = null

for (const block of value) {
  if (block._type === 'block' && block.listItem === 'bullet') {
    const text = (block.children || []).map((c: any) => renderMarks(c.text, c.marks)).join('')
    if (!currentList) currentList = []
    currentList.push(`<li>${text}</li>`)
  } else {
    if (currentList) {
      htmlParts.push(`<ul>${currentList.join('')}</ul>`)
      currentList = null
    }
    htmlParts.push(blockToHtml(block))
  }
}
if (currentList) htmlParts.push(`<ul>${currentList.join('')}</ul>`)

const html = htmlParts.join('\n')
---

<div class="article-content" set:html={html} />

<style is:global>
  .article-content p { margin-bottom: 1.5rem; line-height: 1.8; color: #374151; }
  .article-content h2 { font-family: 'Oswald', sans-serif; font-size: 2rem; font-weight: 700; color: #182b1c; margin-top: 2.5rem; margin-bottom: 1rem; text-transform: uppercase; }
  .article-content h3 { font-family: 'Oswald', sans-serif; font-size: 1.5rem; font-weight: 700; color: #182b1c; margin-top: 2rem; margin-bottom: 1rem; }
  .article-content ul { list-style-type: disc; margin-left: 1.5rem; margin-bottom: 1.5rem; color: #374151; }
  .article-content li { margin-bottom: 0.5rem; }
  .article-content img { border-radius: 0.75rem; margin: 2rem 0; width: 100%; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06); }
  .article-content blockquote { border-left: 4px solid #f6aa1c; background: rgba(249,248,243,0.5); padding: 1.5rem; font-style: italic; color: #374151; margin: 2.5rem 0; border-radius: 0 0.75rem 0.75rem 0; }
</style>
