---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PortableText from '../../components/PortableText.astro'
import { client, urlFor } from '../../lib/sanity'
import { semuaArtikelSlugQuery, artikelBySlugQuery } from '../../lib/queries'

export async function getStaticPaths() {
  const slugs = await client.fetch(semuaArtikelSlugQuery)
  return slugs.map((item: { slug: string }) => ({ params: { slug: item.slug } }))
}

const { slug } = Astro.params
const artikel = await client.fetch(artikelBySlugQuery, { slug })

if (!artikel) {
  return Astro.redirect('/404')
}

const artikelTerkait = artikel.artikelTerkaitManual?.length
  ? artikel.artikelTerkaitManual
  : artikel.artikelTerkaitOtomatis

function formatTanggal(iso: string) {
  return new Date(iso).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })
}
---

<BaseLayout title={artikel.seo?.metaTitle || artikel.judul} description={artikel.seo?.metaDescription || artikel.ringkasan} ogImage={artikel.seo?.ogImage || artikel.gambarUtama}>

  <section class="relative w-full h-[70svh] min-h-[500px] flex flex-col justify-end items-center overflow-hidden bg-brand-dark pt-24">
    {artikel.gambarUtama && (
      <div class="absolute inset-0 w-full h-full bg-cover bg-center" style={`background-image: url('${urlFor(artikel.gambarUtama).width(1600).url()}')`}></div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-brand-forest via-black/50 to-black/20 z-0"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 w-full text-center pb-16">
      {artikel.kategori && (
        <div class="inline-block bg-brand-mustard text-brand-forest text-xs font-bold px-3 py-1 rounded-sm mb-4 uppercase tracking-widest shadow-md">{artikel.kategori.nama}</div>
      )}
      <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-tight mb-6 uppercase drop-shadow-lg">{artikel.judul}</h1>
      <div class="flex items-center justify-center gap-4 text-white/80 text-sm font-medium">
        <div class="flex items-center gap-2"><i class="fa-solid fa-user text-brand-mustard"></i> {artikel.penulis}</div>
        <div class="w-1 h-1 rounded-full bg-white/50"></div>
        <div class="flex items-center gap-2"><i class="fa-regular fa-calendar text-brand-mustard"></i> {formatTanggal(artikel.tanggalTerbit)}</div>
      </div>
    </div>
  </section>

  <article class="w-full py-16 bg-white relative z-10 -mt-8 rounded-t-[2rem] shadow-[0_-10px_40px_rgba(0,0,0,0.05)] border-b border-gray-100">
    <div class="max-w-3xl mx-auto px-6">
      {artikel.tags?.length > 0 && (
        <div class="flex flex-wrap items-center gap-2 pb-8 mb-8 border-b border-gray-100 text-sm font-bold text-gray-500 uppercase tracking-widest">
          <i class="fa-solid fa-tags text-brand-mustard"></i>
          {artikel.tags.join(', ')}
        </div>
      )}

      <PortableText value={artikel.konten} />

      <div class="mt-12 p-6 bg-brand-cream border border-gray-200 rounded-xl flex items-center gap-6">
        <div class="w-16 h-16 rounded-full bg-brand-forest flex items-center justify-center text-brand-mustard text-2xl shrink-0">
          <i class="fa-solid fa-pen-nib"></i>
        </div>
        <div>
          <h4 class="font-bold text-brand-forest text-lg">Ditulis oleh {artikel.penulis}</h4>
        </div>
      </div>
    </div>
  </article>

  {artikelTerkait?.length > 0 && (
    <section class="w-full py-20 bg-brand-cream relative z-10 border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-center justify-between mb-10 border-b-2 border-gray-200 pb-4">
          <h2 class="font-heading text-3xl font-bold text-brand-forest uppercase">Baca <span class="text-brand-mustard">Juga</span></h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          {artikelTerkait.map((a: any) => (
            <a href={`/artikel/${a.slug}`} class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex flex-col group transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
              <div class="h-48 w-full relative overflow-hidden">
                {a.gambarUtama && <img src={urlFor(a.gambarUtama).width(500).height(350).url()} alt={a.judul} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />}
              </div>
              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center gap-2 text-xs text-gray-500 mb-3 font-semibold"><i class="fa-regular fa-calendar"></i> {formatTanggal(a.tanggalTerbit)}</div>
                <h4 class="font-bold text-xl text-brand-forest mb-3 leading-snug group-hover:text-brand-red transition-colors font-heading tracking-wide">{a.judul}</h4>
                <p class="text-sm text-gray-600 line-clamp-3 mb-4">{a.ringkasan}</p>
                <span class="mt-auto text-sm font-bold text-brand-red flex items-center gap-2">Baca Selengkapnya <i class="fa-solid fa-arrow-right text-xs"></i></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
