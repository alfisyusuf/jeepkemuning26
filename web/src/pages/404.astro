---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Halaman Tidak Ditemukan">
  <section class="w-full min-h-[70vh] flex flex-col items-center justify-center text-center px-6 pt-24">
    <h1 class="font-heading text-6xl md:text-8xl font-bold text-brand-forest mb-4">404</h1>
    <p class="text-gray-600 mb-8 max-w-md">Halaman yang kamu cari tidak ditemukan atau sudah dipindahkan.</p>
    <a href="/" class="bg-brand-red hover:bg-red-800 text-white font-bold px-8 py-3.5 rounded-md transition-colors shadow-md">Kembali ke Beranda</a>
  </section>
</BaseLayout>
