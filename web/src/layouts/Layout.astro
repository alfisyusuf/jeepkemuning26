---
import '../styles/global.css';
import { sanityClient } from "sanity:client";

// Menerima prop title halaman
const { title = "Jeep Kemuning - Petualangan Alam Terbaik" } = Astro.props;

// Tarik data Pengaturan dari Sanity (dengan fallback statis jika klien belum mengisi)
const query = `*[_type == "siteSettings"][0]`;
const settings = await sanityClient.fetch(query);

const waNumber = settings?.whatsapp || "628561304343";
const waFormat = waNumber.replace(/^62/, '0'); // Ubah format 62 ke 0 untuk tampilan teks
const email = settings?.email || "halo@jeepkemuning.com";
const alamat = settings?.alamat || "Basecamp Kemuning Adventure, Desa Kemuning, Kec. Ngargoyoso";
const ig = settings?.instagramUrl || "https://instagram.com/jeepkemuning";
const tagline = settings?.tagline || "Petualangan Seru, Cerita Tak Terlupakan.";
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,700&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="antialiased bg-brand-cream text-gray-800 relative overflow-x-hidden">

  <header class="absolute top-0 w-full z-50 bg-white/95 backdrop-blur-sm shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-6 py-2.5 flex items-center justify-between"> 
      <a href="/" class="flex items-center gap-3 flex-shrink-0 z-50">
        <img src="/images/logo-jeepkemuning.png" alt="Logo Jeep Kemuning" class="h-10 md:h-12 w-auto drop-shadow-sm">
        <div class="font-heading font-bold text-xl md:text-2xl tracking-tight uppercase hidden sm:block">
          <span class="text-brand-forest">jeep</span><span class="text-brand-mustard">kemuning</span>
        </div>
      </a>

      <nav class="hidden lg:flex flex-1 justify-center items-center gap-8 text-sm font-semibold text-gray-700">
        <a href="/" class="hover:text-brand-red transition-colors">Beranda</a>
        <a href="/tentang" class="hover:text-brand-red transition-colors">Tentang Kami</a>
        <a href="/paket" class="hover:text-brand-red transition-colors">Paket Wisata</a>
        <a href="/artikel" class="hover:text-brand-red transition-colors">Artikel</a>
      </nav>

      <div class="flex items-center gap-4 flex-shrink-0">
        <a href={`https://wa.me/${waNumber}`} target="_blank" class="hidden lg:flex items-center gap-2 bg-brand-red text-white px-6 py-2.5 rounded-md text-sm font-bold hover:bg-red-800 transition-colors shadow-md">
          <i class="fa-solid fa-phone"></i> Book Now
        </a>

        <button id="mobile-menu-btn" class="lg:hidden z-50 text-brand-forest focus:outline-none p-1">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <div id="mobile-menu" class="fixed inset-0 bg-white z-40 transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden flex flex-col px-6 pb-8 pt-24 overflow-y-auto">
    <div class="flex items-center justify-center gap-2 mb-10 pb-6 border-b border-gray-100">
      <img src="/images/logo-jeepkemuning.png" alt="Logo" class="h-12 w-auto">
      <div class="font-heading font-bold text-2xl tracking-tight uppercase">
        <span class="text-brand-forest">jeep</span><span class="text-brand-mustard">kemuning</span>
      </div>
    </div>
    <nav class="flex flex-col gap-6 text-lg font-semibold text-brand-forest items-center">
      <a href="/">Beranda</a>
      <a href="/tentang">Tentang Kami</a>
      <a href="/paket">Paket Wisata</a>
      <a href="/artikel">Artikel</a>
    </nav>
    <a href={`https://wa.me/${waNumber}`} target="_blank" class="mt-auto mb-4 flex items-center justify-center gap-2 bg-brand-red hover:bg-red-800 text-white w-full py-4 rounded-md text-base font-bold transition-colors shadow-md">
      <i class="fa-solid fa-phone"></i> Book Now
    </a>
  </div>

  <slot />

  <footer class="relative z-10 w-full px-6 py-12 text-brand-cream/80 text-sm bg-brand-dark">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">
      <div>
        <h4 class="font-bold text-white mb-4 uppercase tracking-wider">Informasi Kontak</h4>
        <div class="flex items-start gap-3 mb-4">
          <i class="fa-solid fa-location-dot mt-1 text-brand-red"></i>
          <p>Alamat:<br>{alamat}</p>
        </div>
        <div class="flex items-center gap-3">
          <i class="fa-brands fa-whatsapp text-brand-mustard text-lg"></i>
          <p>WhatsApp:<br><a href={`https://wa.me/${waNumber}`} class="text-white font-bold hover:text-brand-mustard transition-colors">{waFormat}</a></p>
        </div>
      </div>
      <div class="lg:pt-9">
        <div class="flex items-center gap-3 mb-4">
          <i class="fa-regular fa-envelope text-lg text-brand-mustard"></i>
          <p>Email:<br><a href={`mailto:${email}`} class="hover:text-white transition-colors">{email}</a></p>
        </div>
        <div class="flex items-center gap-3">
          <i class="fa-brands fa-instagram text-lg text-brand-mustard"></i>
          <p>Instagram:<br><a href={ig} class="hover:text-white transition-colors">@jeepkemuning</a></p>
        </div>
      </div>
      <div>
        <h4 class="font-bold text-white mb-4 uppercase tracking-wider">Tautan Singkat</h4>
        <ul class="flex flex-col gap-2">
          <li><a href="/" class="hover:text-brand-mustard transition-colors">Beranda</a></li>
          <li><a href="/paket" class="hover:text-brand-mustard transition-colors">Paket Wisata</a></li>
          <li><a href="/artikel" class="hover:text-brand-mustard transition-colors">Artikel</a></li>
        </ul>
      </div>
      <div class="flex flex-col items-start lg:items-end text-left lg:text-right">
        <a href="/" class="mb-2 block flex flex-col items-start lg:items-end">
           <img src="/images/logo-jeepkemuning.png" alt="Logo Jeep Kemuning" class="h-16 w-auto opacity-90 hover:opacity-100 transition-opacity mb-2">
           <div class="font-heading font-bold text-3xl tracking-tight uppercase">
             <span class="text-white">jeep</span><span class="text-brand-mustard">kemuning</span>
           </div>
        </a>
        <p class="text-brand-cream/60 mt-1">{tagline}</p>
      </div>
    </div>
    <div class="text-center pt-8 border-t border-white/10 text-brand-cream/40 text-xs md:text-sm">
      © {new Date().getFullYear()} jeepkemuning.com. Membawa Cerita dari Kemuning.
    </div>
  </footer>

  <script>
    // JS Mobile Menu Toggle
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');

    if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('translate-x-full');
          if(menu.classList.contains('translate-x-full')) {
            btn.innerHTML = `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>`;
          } else {
            btn.innerHTML = `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>`;
          }
        });
    }
  </script>
</body>
</html>